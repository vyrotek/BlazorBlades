<Project>
    <Target
      Name="BlazorBladesAddRazorComponentsAsAdditionalFiles"
      BeforeTargets="CoreCompile"
      Condition="'$(UsingMicrosoftNETSdkRazor)' == 'true' or '$(UsingMicrosoftNETSdkWeb)' == 'true'">
        <ItemGroup>
            <AdditionalFiles Include="@(RazorComponent)"
                             Exclude="@(AdditionalFiles)" />
        </ItemGroup>
    </Target>
</Project>